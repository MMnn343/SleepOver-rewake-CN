
# game/script_neutral.rpy:20
translate chinese scene1_motorbikeride_ecdf572c:

    # voice audio.kano_vs1_line1
    # k "The wait is finally over! "
    voice audio.kano_vs1_line1
    k "终于等到这一天了！"

# game/script_neutral.rpy:24
translate chinese scene1_motorbikeride_40eb7419:

    # voice audio.kano_vs1_line2
    # k "{i}(My name is Kano, and I’m a simple guy who lives in a small town, way out in the province.){/i}"
    voice audio.kano_vs1_line2
    k "{i}（我叫Kano，是个住在偏远小镇的普通家伙。）{/i}"
# game/script_neutral.rpy:27
translate chinese scene1_motorbikeride_2c4b09ca:

    # voice audio.kano_vs1_line3
    # k "{i}(Life is quiet out here – I work at a corner store owned by my parents, live in my childhood home, and focus on my hobbies.){/i}"
    voice audio.kano_vs1_line3
    k "{i}（这里的生活很安静——我在父母开的便利店工作，住在从小长大的房子里，专注于自己的爱好。）{/i}"
# game/script_neutral.rpy:31
translate chinese scene1_motorbikeride_ab33f57e:

    # voice audio.kano_vs1_line4
    # k "{i}(But obviously the reason I’m excited today is ’cause it’s a special day!){/i}"
    voice audio.kano_vs1_line4
    k "{i}（但今天让我兴奋的原因很明显，因为是个特别的日子！）{/i}"
# game/script_neutral.rpy:34
translate chinese scene1_motorbikeride_03bf88ac:

    # voice audio.kano_vs1_line5
    # k "{i}(My best friend, Aki, is coming back to town!){/i}"
    voice audio.kano_vs1_line5
    k "{i}（我最好的朋友，Aki，要回镇上了！）{/i}"
# game/script_neutral.rpy:37
translate chinese scene1_motorbikeride_40d54a58:

    # voice audio.kano_vs1_line6
    # k "{i}(I haven’t seen him in years, and he’s always too busy to text or talk much, but we used to be inseparable growing up. I wonder how much he’s changed?){/i}"
    voice audio.kano_vs1_line6
    k "{i}（我好几年没见他了，他总是太忙，没空发短信或聊天，但我们小时候形影不离。不知道他变了多少？）{/i}"
# game/script_neutral.rpy:40
translate chinese scene1_motorbikeride_0945773f:

    # voice audio.kano_vs1_line7
    # k "{i}(From what I remember of Aki, he was always smart, cool, and collected. Basically, the complete opposite of me! It’s why I always admired him!){/i}"
    voice audio.kano_vs1_line7
    k "{i}（据我对Aki的记忆，他一直聪明、冷静、沉着。基本上和我完全相反！这就是我一直钦佩他的原因！）{/i}"
# game/script_neutral.rpy:44
translate chinese scene1_motorbikeride_a9ca665b:

    # voice audio.kano_vs1_line8
    # k "{i}(So, when he left town years ago, it made me really sad…){/i}"
    voice audio.kano_vs1_line8
    k "{i}（所以，几年前他离开小镇时，我真的很伤心……）{/i}"
# game/script_neutral.rpy:48
translate chinese scene1_motorbikeride_32fd865c:

    # voice audio.kano_vs1_line9
    # k "{i}(But I knew that a guy like him was gonna have a successful life in the city! I even still brag about him regularly to our customers, and my family!){/i}"
    voice audio.kano_vs1_line9
    k "{i}（但我知道像他这样的人一定会在城市里过上成功的生活！我甚至现在还经常向我们的顾客和家人夸他！）{/i}"
# game/script_neutral.rpy:51
translate chinese scene1_motorbikeride_f9d0e7fd:

    # voice audio.kano_vs1_line10
    # k "{i}(I really wonder what would make him wanna leave all that and come back here to the middle of nowhere today.){/i}"
    voice audio.kano_vs1_line10
    k "{i}（我真的很想知道，是什么让他愿意放弃这一切，今天回到这个鸟不拉屎的地方。）{/i}"
# game/script_neutral.rpy:54
translate chinese scene1_motorbikeride_d1b841de:

    # voice audio.kano_vs1_line11
    # k "{i}(It’s really out of the blue for him to text me and ask to meet up at our old hangout spot. I have a gut feeling there’s something going on…){/i}"
    voice audio.kano_vs1_line11
    k "{i}（他突然发短信约我在我们以前的老地方见面，真的很突然。我有种直觉，肯定有什么事……）{/i}"
# game/script_neutral.rpy:58
translate chinese scene1_motorbikeride_ce897c53:

    # voice audio.kano_vs1_line12
    # k "Whatever it is, it doesn’t matter! I just can’t wait to be with Aki again!"
    voice audio.kano_vs1_line12
    k "不管是什么，都不重要！我只想快点再见到Aki！"
# game/script_neutral.rpy:86
translate chinese scene1_motorbikeride_dd3ffd04:

    # voice audio.aki_vs2_line1
    voice audio.aki_vs2_line1

# game/script_neutral.rpy:88
translate chinese scene1_motorbikeride_85c97ff2:

    # a "Well, look who it is! Kano, you haven’t changed a bit!"
    a "哎呀，瞧这是谁啊！Kano，你一点都没变！"

# game/script_neutral.rpy:90
translate chinese scene1_motorbikeride_a00892b3:

    # voice audio.kano_vs2_line1
    # k "Aki!!! It’s so good to see you, but I can’t say the same – you look different…"
    voice audio.kano_vs2_line1
    k "Aki！！！见到你真好，但我得说——你看起来不一样了……"
# game/script_neutral.rpy:94
translate chinese scene1_motorbikeride_d5c98b00:

    # voice audio.aki_vs2_line2
    voice audio.aki_vs2_line2

# game/script_neutral.rpy:96
translate chinese scene1_motorbikeride_899e6953:

    # a "Huh? How so?"
    a "嗯？怎么说？"

# game/script_neutral.rpy:102
translate chinese scene1_motorbikeride_ac855b35:

    # a "Huh? How so?{fast}" nointeract
    a "嗯？怎么说？{fast}" nointeract

# game/script_neutral.rpy:107
translate chinese scene1_motorbikeride_d7706220:

    # voice audio.kano_vs2_line2a
    # k "You’ve lost a lot of weight since the last time I saw you!"
    voice audio.kano_vs2_line2a
    k "你比我上次见你的时候瘦了好多！"
# game/script_neutral.rpy:110
translate chinese scene1_motorbikeride_e1cbd176:

    # voice audio.aki_vs2_line3a
    # a "Kano, that was years ago. I’ve not been chubby for a long time."
    voice audio.aki_vs2_line3a
    a "Kano，那是几年前的事了。我早就不是胖乎乎的了。"
# game/script_neutral.rpy:113
translate chinese scene1_motorbikeride_c28efb9c:

    # voice audio.kano_vs2_line3a
    # k "ACK! I didn’t mean it that way!"
    voice audio.kano_vs2_line3a
    k "啊！我不是那个意思！"
# game/script_neutral.rpy:117
translate chinese scene1_motorbikeride_b4037f94:

    # voice audio.aki_vs2_line4a
    # a "*sigh* It’s fine. I’ll take it as a compliment, I guess…"
    voice audio.aki_vs2_line4a
    a "*叹气* 没事。我就当是夸奖了，大概……"
# game/script_neutral.rpy:123
translate chinese scene1_motorbikeride_7f2d24b4:

    # voice audio.kano_vs2_line2b
    # k "You’re so different from how I remember, are you sure you’re Aki?"
    voice audio.kano_vs2_line2b
    k "你和我记忆中的样子差太多了，你真的是Aki吗？"
# game/script_neutral.rpy:126
translate chinese scene1_motorbikeride_b5e44fb9:

    # voice audio.aki_vs2_line3b
    # a "Don’t be silly, Kano. Of course it’s me."
    voice audio.aki_vs2_line3b
    a "别傻了，Kano。当然是我。"
# game/script_neutral.rpy:129
translate chinese scene1_motorbikeride_c6cdcba9:

    # voice audio.kano_vs2_line3b
    # k "Haha, right… It's just been so long…"
    voice audio.kano_vs2_line3b
    k "哈哈，是啊……只是太久没见了……"
# game/script_neutral.rpy:135
translate chinese scene1_motorbikeride_47ee0a88:

    # voice audio.kano_vs2_line2c
    # k "You’ve got a new style! Love the new haircut!"
    voice audio.kano_vs2_line2c
    k "你换新造型了！喜欢你的新发型！"
# game/script_neutral.rpy:138
translate chinese scene1_motorbikeride_a5a10d30:

    # voice audio.aki_vs2_line3c
    # a "Thanks. I’ve been trying to take care of myself."
    voice audio.aki_vs2_line3c
    a "谢谢。我一直努力在照顾自己。"
# game/script_neutral.rpy:141
translate chinese scene1_motorbikeride_8dd900c1:

    # voice audio.kano_vs2_line3c
    # k "I guess this is how city-people look, huh?"
    voice audio.kano_vs2_line3c
    k "我猜这就是城里人的样子吧？"
# game/script_neutral.rpy:145
translate chinese scene1_motorbikeride_e38515d2:

    # voice audio.aki_vs2_line4c
    # a "Haha, don’t be silly, Kano. It’s not that different there."
    voice audio.aki_vs2_line4c
    a "哈哈，别傻了，Kano。那里也没那么不同。"
# game/script_neutral.rpy:151
translate chinese scene1_motorbikeride_51f3b358:

    # voice audio.kano_vs2_line2d
    # k "You’re hot now!"
    voice audio.kano_vs2_line2d
    k "你现在好辣！"
# game/script_neutral.rpy:154
translate chinese scene1_motorbikeride_82fb4be9:

    # voice audio.aki_vs2_line3d
    # a "H-Hey…! How is that the first thing you say when you meet me…?"
    voice audio.aki_vs2_line3d
    a "喂——！你见到我说的第一句话就是这个……？"
# game/script_neutral.rpy:157
translate chinese scene1_motorbikeride_aee5e443:

    # voice audio.kano_vs2_line3d
    # k "Ack, sorry! You’re just more handsome than I remember."
    voice audio.kano_vs2_line3d
    k "啊，抱歉！你只是比我记忆中更帅了。"
# game/script_neutral.rpy:160
translate chinese scene1_motorbikeride_405b427c:

    # voice audio.aki_vs2_line4d
    # a "Kano you’re just making it worse…"
    voice audio.aki_vs2_line4d
    a "Kano，你这是在火上浇油……"
# game/script_neutral.rpy:163
translate chinese scene1_motorbikeride_25998daa:

    # voice audio.kano_vs2_line4d
    # k "Huhu… I was just trying to compliment you."
    voice audio.kano_vs2_line4d
    k "呼呼……我只是想夸夸你。"
# game/script_neutral.rpy:167
translate chinese scene1_motorbikeride_c8d83c4a:

    # voice audio.aki_vs2_line5d
    # a "Hahaha, good to see you really are the same."
    voice audio.aki_vs2_line5d
    a "哈哈哈，很高兴看到你还是老样子。"
# game/script_neutral.rpy:171
translate chinese scene1_motorbikeride_40c5455e:

    # voice audio.aki_vs2_line6
    # a "Anyway, what’s that motorbike behind you? You finally learned how to drive?"
    voice audio.aki_vs2_line6
    a "话说回来，你身后那辆摩托车是怎么回事？你终于学会开车了？"
# game/script_neutral.rpy:174
translate chinese scene1_motorbikeride_961c5fda:

    # voice audio.kano_vs2_line5
    # k "Hehe, yup! Not only that, but I bought that bike myself – it’s secondhand, but it runs well!"
    voice audio.kano_vs2_line5
    k "嘿嘿，没错！而且那辆摩托车是我自己买的——虽然是二手的，但跑起来可带劲了！"
# game/script_neutral.rpy:177
translate chinese scene1_motorbikeride_ca46c50b:

    # voice audio.kano_vs2_line6
    # k "Not to brag, but I got super into fixing it up! This thing was covered in rust and old parts, and I’ve been slowly turning it into a brand-new hotrod!"
    voice audio.kano_vs2_line6
    k "不是吹牛，我超级投入地把它翻新了一遍！这玩意儿原本锈迹斑斑，零件老旧，我一点一点把它改造成了全新的改装车！"
# game/script_neutral.rpy:181
translate chinese scene1_motorbikeride_1cd31e69:

    # voice audio.aki_vs2_line7
    # a "Haha, I don’t think I’ve ever heard a motorbike described as a hotrod, but it’s cool you got into mechanics like that – I wouldn’t have expected that!"
    voice audio.aki_vs2_line7
    a "哈哈，我还是头一回听人把摩托车说成改装车，不过你能这么投入机械修理真酷——我完全没想到你会干这个！"
# game/script_neutral.rpy:184
translate chinese scene1_motorbikeride_4010d2ce:

    # voice audio.kano_vs2_line7
    # k "Enough about me, though! What about you? How’s life in the city?!"
    voice audio.kano_vs2_line7
    k "不过别光说我了！你呢？城里生活怎么样？"
# game/script_neutral.rpy:188
translate chinese scene1_motorbikeride_6424cca0:

    # voice audio.aki_vs2_line8
    # a "Huh? Oh, it’s alright. You know, the usual stuff."
    voice audio.aki_vs2_line8
    a "嗯？哦，还行吧。你知道的，老样子。"
# game/script_neutral.rpy:191
translate chinese scene1_motorbikeride_8470b365:

    # voice audio.kano_vs2_line8
    # k "Nuh-uh, I don’t know! I can only imagine it’s so different from here! What about school? Are you blowing everyone away with how smart you are?!"
    voice audio.kano_vs2_line8
    k "不不，我不知道！我只能想象这里和那里完全不同！学校呢？你是不是聪明得把所有人都比下去了？！"
# game/script_neutral.rpy:195
translate chinese scene1_motorbikeride_cf57bc5a:

    # voice audio.aki_vs2_line9
    # a "S-School’s fine, I’m in my last semester. I’ll be graduating soon, especially since finals just concluded. "
    voice audio.aki_vs2_line9
    a "学、学校还好，我最后一个学期了。很快就要毕业了，尤其是期末考试刚结束。"
# game/script_neutral.rpy:198
translate chinese scene1_motorbikeride_6050dc60:

    # voice audio.kano_vs2_line9
    # k "No way, that’s awesome! I bet you already have a job lined up too – you’re probably gonna be a top-tier office guy right off the bat, huh?"
    voice audio.kano_vs2_line9
    k "不会吧，太棒了！我打赌你工作也找好了——你大概一毕业就能当上顶级白领吧，嗯？"
# game/script_neutral.rpy:202
translate chinese scene1_motorbikeride_867186cf:

    # voice audio.aki_vs2_line10
    # a "Eh, I don’t know about that…"
    voice audio.aki_vs2_line10
    a "呃，这倒不一定……"
# game/script_neutral.rpy:204
translate chinese scene1_motorbikeride_39e7521b:

    # k "{i}(That’s weird… Is it just me or is Aki being a little dismissive?){/i}"
    k "{i}（真奇怪……是只有我觉得 Aki 有点冷淡吗？）{/i}"

# game/script_neutral.rpy:205
translate chinese scene1_motorbikeride_7678a829:

    # k "{i}(Or maybe he’s just tired from the train ride? It’s a long way from the city to way out here after all…){/i}"
    k "{i}（或者他只是坐火车累了？毕竟从城里到这么远的地方路很长……）{/i}"

# game/script_neutral.rpy:208
translate chinese scene1_motorbikeride_6f4fd695:

    # voice audio.kano_vs2_line10
    # k "Oh yeah, so why did you come back home today? I was shocked when you texted me last night!"
    voice audio.kano_vs2_line10
    k "哦对了，那你今天为什么回家？昨晚你发短信给我时我吓了一跳！"
# game/script_neutral.rpy:211
translate chinese scene1_motorbikeride_8cef74b4:

    # voice audio.kano_vs2_line11
    # k "Lemme guess – it’s to celebrate your graduation! "
    voice audio.kano_vs2_line11
    k "让我猜猜——是为了庆祝你毕业吧！"
# game/script_neutral.rpy:215
translate chinese scene1_motorbikeride_e73caa3c:

    # voice audio.aki_vs2_line11
    # a "Th-There’s plenty of time to talk about that later. For now, don’t you wanna head inside? "
    voice audio.aki_vs2_line11
    a "那、那件事以后再说也不迟。现在，你不想先进去吗？"
# game/script_neutral.rpy:218
translate chinese scene1_motorbikeride_de315577:

    # voice audio.kano_vs2_line12
    # k "Right, daylight’s burning – let’s go!"
    voice audio.kano_vs2_line12
    k "对，时间不等人——我们走吧！"
# game/script_neutral.rpy:249
translate chinese scene1_motorbikeride_46bb4c2d:

    # voice audio.aki_vs3_line1
    # a "Woah, now this place REALLY hasn’t changed."
    voice audio.aki_vs3_line1
    a "哇，这地方真的一点都没变。"
# game/script_neutral.rpy:253
translate chinese scene1_motorbikeride_1fe94ea6:

    # voice audio.kano_vs3_line1
    # k "I know, right?! Isn’t it awesome – it’s exactly the way you left it!"
    voice audio.kano_vs3_line1
    k "对吧？！是不是超棒——跟你离开时一模一样！"
# game/script_neutral.rpy:257
translate chinese scene1_motorbikeride_cb8c4664:

    # voice audio.aki_vs3_line2
    # a "Awesome isn’t exactly the word I’d use to describe it… Couldn’t they have at least repainted the walls…? Or replaced the carpet?"
    voice audio.aki_vs3_line2
    a "用“棒极了”来形容可不太准确……他们至少也该重新刷刷墙吧？或者换换地毯？"
# game/script_neutral.rpy:261
translate chinese scene1_motorbikeride_1e141242:

    # voice audio.kano_vs3_line2
    # k "But then it wouldn’t have that comforting, moldy smell! "
    voice audio.kano_vs3_line2
    k "但那样就没有那股令人安心的霉味了！"
# game/script_neutral.rpy:265
translate chinese scene1_motorbikeride_f5deec1e:

    # voice audio.aki_vs3_line3
    # a "Mold’s not a good thing, Kano…"
    voice audio.aki_vs3_line3
    a "发霉可不是什么好事，Kano……"
# game/script_neutral.rpy:269
translate chinese scene1_motorbikeride_040065d8:

    # voice audio.kano_vs3_line3
    # k "Heyyyy, don’t blame the small-town arcade, Mr. Big-Shot City Guy! I’m sure this place doesn’t compare to what you have in the city, but that doesn’t mean it’s bad!"
    voice audio.kano_vs3_line3
    k "嘿——别怪小镇游戏厅啊，大城市来的大人物先生！我知道这里比不上你们城里的，但也不至于那么差吧！"
# game/script_neutral.rpy:273
translate chinese scene1_motorbikeride_564f37d9:

    # voice audio.aki_vs3_line4
    # a "Haha, you’re not wrong, I’ve seen some crazy arcades around the university. There’s even one that’s three floors full of nothing but games!"
    voice audio.aki_vs3_line4
    a "哈哈，你说得没错，我在大学附近见过一些超棒的游戏厅。有一家整整三层楼全是游戏！"
# game/script_neutral.rpy:277
translate chinese scene1_motorbikeride_b582f8ae:

    # voice audio.kano_vs3_line4
    # k "Hmph. I like the simple stuff – besides, there’s nothing wrong with a familiar place!"
    voice audio.kano_vs3_line4
    k "哼，我就喜欢简单的东西——再说了，熟悉的地方也没什么不好！"
# game/script_neutral.rpy:281
translate chinese scene1_motorbikeride_9092ba73:

    # voice audio.aki_vs3_line5
    # a "You’re the one comparing it, you know? "
    voice audio.aki_vs3_line5
    a "是你自己在比较吧？"
# game/script_neutral.rpy:285
translate chinese scene1_motorbikeride_3350a71c:

    # voice audio.aki_vs3_line6
    # a "But it does feel nostalgic to be back here… And hold on, is that…?"
    voice audio.aki_vs3_line6
    a "不过回到这里确实让人怀念……等等，那是……？"
# game/script_neutral.rpy:296
translate chinese scene1_motorbikeride_ea9e8dc3:

    # voice audio.kano_vs3_line5
    # k "Hehe, yup! It’s our favorite game – Strip Fighter!"
    voice audio.kano_vs3_line5
    k "嘿嘿，没错！是我们最喜欢的游戏——脱衣格斗！"
# game/script_neutral.rpy:300
translate chinese scene1_motorbikeride_f8b7792d:

    # voice audio.aki_vs3_line7
    # a "No way! This is like a prehistoric model now… I thought it would’ve been cancelled by now."
    voice audio.aki_vs3_line7
    a "不会吧！这都成史前机型了……我还以为早就停办了。"
# game/script_neutral.rpy:304
translate chinese scene1_motorbikeride_29033fbf:

    # voice audio.kano_vs3_line6
    # k "Why? ’Cause the characters get naked while they beat each other up? That was always my favorite part!"
    voice audio.kano_vs3_line6
    k "为什么？因为角色打架时会脱光衣服？那一直是我最喜欢的部分！"
# game/script_neutral.rpy:308
translate chinese scene1_motorbikeride_94d6c041:

    # voice audio.aki_vs3_line8
    # a "Of course it would be… I haven’t thought about this game in years."
    voice audio.aki_vs3_line8
    a "当然会是……我好多年没想过这个游戏了。"
# game/script_neutral.rpy:312
translate chinese scene1_motorbikeride_53a6dacc:

    # voice audio.kano_vs3_line7
    # k "Oh really? Well I’VE been practicing on this exact one EVERY DAY since you left, and you’re finally gonna go down!"
    voice audio.kano_vs3_line7
    k "哦，是吗？我可是从你走后每天都在练这个游戏，你终于要输给我了！"
# game/script_neutral.rpy:316
translate chinese scene1_motorbikeride_64938a8f:

    # voice audio.aki_vs3_line9
